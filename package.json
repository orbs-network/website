{
  "name": "orbs-website",
  "version": "1.0.0",
  "description": "Website for Orbs.com",
  "main": "index.js",
  "scripts": {
    "prebuild": "sh prebuild.sh",
    "build": "cuttlebelle",
    "postbuild": "cp 404.html ./site/404.html",
    "test": "echo \"Error: no test specified\" && exit 1",
    "sass-prebuild": "sass ./assets/sass/index.scss ./assets/css/index.css",
    "watch-sass": "sass -w ./assets/sass/index.scss ./assets/css/index.css",
    "dev": "yarn watch-sass & cross-env IS_DEV=true cuttlebelle -w & node dev-server.js",
    "watch": "yarn watch-sass & cross-env IS_DEV=true cuttlebelle -w",
    "watch-prod": "yarn watch-sass & cuttlebelle -w"
  },
  "cuttlebelle": {
    "site": {
      "markdownRenderer": "markdown.js"
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cross-env": "^7.0.3",
    "globe.gl": "^2.21.1",
    "moment": "^2.29.1",
    "node-html-parser": "^5.3.3",
    "sass": "^1.45.1"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "cuttlebelle": "^1.0.0-alpha.80"
  }
}
